# Frontend stack env for AWS deployment
# Copy to .env and fill in values

FRONTEND_PORT=3000

# Backend URL — uses Docker service name on shared network (same-machine deployment)
# For cross-machine deployment, use http://<BACKEND_EC2_IP>:8000 instead
BACKEND_INTERNAL_URL=http://organisational-layer:8000
# Optional. If omitted, frontend derives this as BACKEND_INTERNAL_URL with port 8080.
LOGICAL_BACKEND_INTERNAL_URL=http://logical-layer:8080
# Optional server-only Anthropic config for frontend chat intake route.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-7-sonnet-20250219
NEXT_PUBLIC_API_BASE_URL=/api

# Optional S3 config for file uploads. Leave empty to disable upload route.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=

# MySQL container settings (only needed if running local MySQL instead of RDS)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=chainiq
MYSQL_USER=chainiq
MYSQL_PASSWORD=chainiq
MYSQL_PORT=3306
