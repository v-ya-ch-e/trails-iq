# TrailsIQ frontend environment for a deployed backend
# Copy to .env.deployed and replace the placeholder URLs.

FRONTEND_PORT=3000

# Use Docker service names for same-machine Docker deployment, or HTTPS URLs for
# separately hosted backend services.
BACKEND_INTERNAL_URL=http://organisational-layer:8000
LOGICAL_BACKEND_INTERNAL_URL=http://logical-layer:8080

# Optional server-only Anthropic config for frontend chat intake route.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-7-sonnet-20250219
NEXT_PUBLIC_API_BASE_URL=/api

# Optional S3 config for file uploads. Leave empty to disable upload route.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=
